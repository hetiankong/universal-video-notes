# API 配置 (必需)
DEEPSEEK_API_KEY=sk-xxxxx
# 或者使用 OPENAI_API_KEY
# OPENAI_API_KEY=sk-xxxxx

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 本地 ASR 配置（可选）
# SENSEVOICE_DEVICE=cuda|cpu|auto
# SENSEVOICE_MODEL_PATH=iic/SenseVoiceSmall

# 飞书 Wiki 配置（可选，用于自动上传）
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_WIKI_SPACE_ID=7xxxxxx
# FEISHU_WIKI_PARENT_NODE=wikcnXXX
# FEISHU_NOTIFY_USER_ID=ou_xxxxxxxx

# Obsidian 配置（可选）
# OBSIDIAN_OUTPUT_DIR=/path/to/your/obsidian/vault/

# Local REST API 配置（可选，用于触发同步）
# LOCAL_REST_API_KEY=your_api_key
# LOCAL_REST_API_URL=http://127.0.0.1:27123
